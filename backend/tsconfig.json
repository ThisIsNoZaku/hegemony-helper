{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "Node16",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Output */
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,

    /* Module resolution */
    "moduleResolution": "Node16",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
